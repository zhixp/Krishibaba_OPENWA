# Environment Variables for Krishi Baba Backend
# Copy this file to .env and fill in your values

# Required: Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenWeather API Key (for weather features)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Admin API Key for protected endpoints
ADMIN_API_KEY=change_this_to_secure_random_key

# Database (default is SQLite)
DATABASE_URL=sqlite+aiosqlite:///./krishi_baba.db

# CORS Origins (comma-separated)
# Add admin or future client domains here
CORS_ORIGINS=http://localhost:8080,https://krishibaba.com

# App Settings
DEBUG=false
MAX_AUDIO_SIZE_MB=5
AUDIO_UPLOAD_PATH=./uploads/audio

# Prompts Configuration
PROMPTS_PATH=./app/core/prompts.yaml
